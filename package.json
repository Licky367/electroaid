{
  "name": "electroaid-system",
  "version": "1.0.0",
  "description": "Electro-Aid Full System (Client, Admin, Expert)",
  "main": "server-admin.js",
  "scripts": {
    "start": "node server-admin.js",

    "start:admin": "node server-admin.js",
    "start:client": "node server-client.js",
    "start:expert": "node server-expert.js",

    "start:all": "concurrently \"node server-admin.js\" \"node server-client.js\" \"node server-expert.js\"",

    "dev": "nodemon server-admin.js",

    "dev:admin": "nodemon server-admin.js",
    "dev:client": "nodemon server-client.js",
    "dev:expert": "nodemon server-expert.js",

    "dev:all": "concurrently \"nodemon server-admin.js\" \"nodemon server-client.js\" \"nodemon server-expert.js\""
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "ejs": "^3.1.9",
    "express": "^4.18.2",
    "express-session": "^1.17.3",
    "express-mysql-session": "^2.1.8",
    "mysql2": "^3.9.7",
    "concurrently": "^9.0.1"
  },
  "devDependencies": {
    "nodemon": "^3.0.2"
  },
  "engines": {
    "node": ">=18"
  }
}