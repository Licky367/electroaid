<!DOCTYPE html>
<html lang="en">

<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>Admin Registration | Electro-Aid Technologies</title>

<style>
*{ box-sizing:border-box; margin:0; padding:0; }

body{
font-family:Arial,sans-serif;
background:#8B4513;
display:flex;
justify-content:center;
align-items:center;
min-height:100vh;
}

.signup-box{
background:white;
padding:35px;
border-radius:15px;
width:380px;
box-shadow:0 4px 15px rgba(0,0,0,0.3);
}

h2{
text-align:center;
margin-bottom:10px;
color:#8B4513;
}

.sub{
text-align:center;
font-size:13px;
color:#777;
margin-bottom:20px;
}

label{
display:block;
margin-bottom:6px;
font-weight:bold;
}

input{
width:100%;
padding:10px;
margin-bottom:15px;
border:1px solid #ccc;
border-radius:6px;
}

/* READONLY EMAIL */
.readonly{
background:#f5f5f5;
cursor:not-allowed;
}

/* AVATAR */
.avatar-container{
display:flex;
justify-content:center;
margin-bottom:15px;
cursor:pointer;
}

.avatar{
width:90px;
height:90px;
border-radius:50%;
object-fit:cover;
border:3px solid #D2691E;
}

#ADMIN_PROFILE_IMAGE{
display:none;
}

/* PASSWORD */
.password-box{
position:relative;
}

.toggle{
position:absolute;
right:10px;
top:35%;
font-size:13px;
cursor:pointer;
color:#8B4513;
}

/* BUTTON */
button{
width:100%;
padding:10px;
background:#D2691E;
border:none;
color:white;
font-size:16px;
border-radius:6px;
cursor:pointer;
}

button:hover{
background:#a65414;
}

/* STATUS */
.error, .success{
margin-top:10px;
text-align:center;
display:none;
}

.error{ color:red; }
.success{ color:green; }

</style>
</head>

<body>

<div class="signup-box">

<h2>Admin Sign Up</h2>
<p class="sub">Complete your account setup</p>

<form id="ADMIN_SIGNUP_FORM" method="POST" enctype="multipart/form-data">

<!-- TOKEN -->
<input type="hidden" name="token" value="<%= token %>">

<!-- OPTIONAL (for debugging/logging) -->
<input type="hidden" name="ADMIN_EMAIL" value="<%= email %>">

<label>Profile Image</label>

<div class="avatar-container" id="ADMIN_AVATAR_CLICK">
<img id="ADMIN_AVATAR_PREVIEW"
class="avatar"
src="https://cdn-icons-png.flaticon.com/512/149/149071.png">
</div>

<input type="file" id="ADMIN_PROFILE_IMAGE" name="ADMIN_PROFILE_IMAGE" accept="image/*">

<label>Email</label>
<input type="email" value="<%= email %>" readonly class="readonly">

<label>Full Name</label>
<input type="text" name="ADMIN_NAME" required>

<label>Phone Number</label>
<input type="text" name="ADMIN_PHONE" required>

<label>Password</label>

<div class="password-box">
<input type="password" id="ADMIN_PASSWORD" name="ADMIN_PASSWORD" required minlength="6">
<span class="toggle" id="ADMIN_PASSWORD_TOGGLE">Show</span>
</div>

<button type="submit">Create Account</button>

<div id="ADMIN_SIGNUP_ERROR" class="error"></div>
<div id="ADMIN_SIGNUP_SUCCESS" class="success"></div>

</form>

</div>

<script>

/* ELEMENTS */
const form = document.getElementById("ADMIN_SIGNUP_FORM");
const password = document.getElementById("ADMIN_PASSWORD");
const toggle = document.getElementById("ADMIN_PASSWORD_TOGGLE");

const avatarClick = document.getElementById("ADMIN_AVATAR_CLICK");
const avatarInput = document.getElementById("ADMIN_PROFILE_IMAGE");
const avatarPreview = document.getElementById("ADMIN_AVATAR_PREVIEW");

const errorBox = document.getElementById("ADMIN_SIGNUP_ERROR");
const successBox = document.getElementById("ADMIN_SIGNUP_SUCCESS");

const button = form.querySelector("button");

/* AVATAR CLICK */
avatarClick.onclick = () => avatarInput.click();

/* PREVIEW */
avatarInput.onchange = function(){
    const file = this.files[0];
    if(file){
        const reader = new FileReader();
        reader.onload = e => avatarPreview.src = e.target.result;
        reader.readAsDataURL(file);
    }
};

/* PASSWORD TOGGLE */
toggle.onclick = function(){
    if(password.type === "password"){
        password.type = "text";
        toggle.innerText = "Hide";
    } else {
        password.type = "password";
        toggle.innerText = "Show";
    }
};

/* SUBMIT */
form.addEventListener("submit", async (e)=>{
    e.preventDefault();

    errorBox.style.display = "none";
    successBox.style.display = "none";

    button.disabled = true;
    button.innerText = "Creating...";

    const formData = new FormData(form);

    try{

        const res = await fetch("/admin/auth/signup", {
            method: "POST",
            body: formData,
            credentials: "include"
        });

        const data = await res.json();

        if(!res.ok){
            errorBox.innerText = data.message || "Signup failed";
            errorBox.style.display = "block";

            button.disabled = false;
            button.innerText = "Create Account";
            return;
        }

        successBox.innerText = "Account created successfully. Redirecting...";
        successBox.style.display = "block";

        setTimeout(()=>{
            window.location.href = "/admin/auth/login";
        }, 2000);

    } catch(err){
        errorBox.innerText = "Server error";
        errorBox.style.display = "block";

        button.disabled = false;
        button.innerText = "Create Account";
    }
});

</script>

</body>
</html>