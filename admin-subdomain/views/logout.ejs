<!DOCTYPE html>
<html lang="en">

<head>

<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>Admin Logout | Electro-Aid Technologies</title>

<style>

*{
box-sizing:border-box;
margin:0;
padding:0;
}

body{
font-family:Arial,sans-serif;
background:#8B4513;
display:flex;
justify-content:center;
align-items:center;
height:100vh;
}

.logout-box{
background:white;
padding:35px;
border-radius:15px;
width:360px;
text-align:center;
box-shadow:0 4px 15px rgba(0,0,0,0.3);
}

h2{
color:#8B4513;
margin-bottom:10px;
}

p{
margin-bottom:20px;
color:#555;
font-size:0.95rem;
}

button{
width:100%;
padding:10px;
border:none;
background:#D2691E;
color:white;
font-size:16px;
border-radius:6px;
cursor:pointer;
}

button:hover{
background:#a65414;
}

.cancel{
margin-top:10px;
background:#999;
}

.cancel:hover{
background:#777;
}

</style>

</head>

<body>

<div class="logout-box">

<h2>Admin Logout</h2>

<p>Are you sure you want to logout?</p>

<button id="ADMIN_LOGOUT_BTN">Logout</button>

<button class="cancel" onclick="window.location.href='/admin/login'">
Cancel
</button>

</div>

<script>

/* ================= CONSTANTS ================= */

const ADMIN_LOGOUT_BTN = document.getElementById("ADMIN_LOGOUT_BTN")

const ADMIN_LOGOUT_API = "/admin/auth/logout"

/* ================= LOGOUT PROCESS ================= */

ADMIN_LOGOUT_BTN.addEventListener("click", async function(){

try{

await fetch(ADMIN_LOGOUT_API,{
method:"POST",
credentials:"include"
})

/* REDIRECT */

window.location.href="/admin/login"

}catch(err){

console.error("Logout error",err)
alert("Logout failed")

}

})

</script>

</body>
</html>