<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>Weekly Expert Payroll</title>

<style>
*{box-sizing:border-box;margin:0;padding:0;}

body{
font-family:Arial,sans-serif;
background:#8B4513;
}

.page-wrapper{
padding-top:130px;
padding-bottom:100px;
}

main{
max-width:1200px;
margin:30px auto;
padding:0 15px;
}

.container{
background:#fff;
padding:20px;
border-radius:18px;
box-shadow:0 5px 15px rgba(0,0,0,0.3);
margin-bottom:25px;
}

h2{
margin-bottom:15px;
color:#8B4513;
}

input,button{
padding:8px;
border-radius:8px;
margin-bottom:10px;
}

input{
border:1px solid #ccc;
width:100%;
}

button{
border:none;
background:#D2691E;
color:#fff;
font-weight:bold;
cursor:pointer;
}

button:hover{background:#A0522D;}
button:disabled{background:grey;cursor:not-allowed;}

table{
width:100%;
border-collapse:collapse;
margin-top:10px;
font-size:0.9rem;
}

th,td{
padding:8px;
border:1px solid #ddd;
text-align:center;
}

th{background:#f2f2f2;}

.status-paid{color:green;font-weight:bold;}
.status-pending{color:red;font-weight:bold;}
.status-processing{color:orange;font-weight:bold;}
.status-failed{color:#b30000;font-weight:bold;}

.total-section{
margin-top:15px;
display:flex;
justify-content:space-between;
flex-wrap:wrap;
gap:10px;
}

.notice{
color:red;
font-weight:bold;
margin-top:10px;
}

.footer{
position:fixed;
bottom:0;
width:100%;
background:#A0522D;
color:#fff;
text-align:center;
padding:10px;
}

.loading{
color:#555;
font-style:italic;
font-size:12px;
}
</style>
</head>

<body>

<%- include("partials/header") %>
<%- include("partials/top-menu") %>

<div class="page-wrapper">
<main>

<div class="container">
<h2>Select Week</h2>

<input type="week" id="weekPicker">
<button onclick="loadWeek()">Load</button>

<p class="notice" id="weekNotice"></p>
</div>

<div class="container">

<h2>Expert Summary</h2>

<table>
<thead>
<tr>
<th>REG_NO</th>
<th>EXPERT_NAME</th>
<th>RECIPIENT</th>
<th>COMPLETED</th>
<th>TOTAL (USD / KES)</th>
<th>STATUS</th>
<th>RETRY</th>
<th>NEXT RETRY</th>
<th>TRANSACTION</th>
<th>ACTION</th>
</tr>
</thead>

<tbody id="summaryTable"></tbody>
</table>

<div class="total-section">

<div>
<strong>Total To Pay (KES):</strong>
<span id="totalAmount">0</span>
</div>

<div>
<button id="payAllBtn" onclick="payAll()">Pay All</button>
<button onclick="downloadPayroll()">Download CSV</button>
</div>

</div>

</div>

</main>
</div>

<div class="footer">
&copy; 2026 Electro-Aid Technologies
</div>

<script>

/* ================= CONFIG ================= */
const BASE = "/admin/invoice";
const MAX_RETRIES = 3;

/* fallback only for display safety */
const USD_TO_KES = <%= typeof rate !== "undefined" ? rate : 130 %>;

/* ================= STATE ================= */
let selectedWeek="";
let selectedDate="";
let selectedWeekIsCurrent=false;
let payrollData=[];

/* ================= WEEK → DATE ================= */
function getDateFromWeek(weekStr){
    const [year, week] = weekStr.split("-W").map(Number);

    const simple = new Date(year, 0, 1 + (week - 1) * 7);
    const day = simple.getDay();

    const monday = new Date(simple);
    if (day <= 4)
        monday.setDate(simple.getDate() - simple.getDay() + 1);
    else
        monday.setDate(simple.getDate() + 8 - simple.getDay());

    return monday.toISOString();
}

/* ================= CURRENT WEEK ================= */
function getCurrentWeek(){
    const now=new Date();
    const firstJan=new Date(now.getFullYear(),0,1);
    const days=Math.floor((now-firstJan)/(24*60*60*1000));
    const week=Math.ceil((days+firstJan.getDay()+1)/7);
    return`${now.getFullYear()}-W${String(week).padStart(2,'0')}`;
}

/* ================= LOAD ================= */
async function loadWeek(){

    selectedWeek=document.getElementById("weekPicker").value;

    if(!selectedWeek){
        alert("Select week");
        return;
    }

    selectedDate = getDateFromWeek(selectedWeek);
    selectedWeekIsCurrent = (selectedWeek === getCurrentWeek());

    document.getElementById("weekNotice").innerText =
    selectedWeekIsCurrent
    ? "⚠ Payments are locked for the current week until it ends."
    : "";

    const table=document.getElementById("summaryTable");
    table.innerHTML=`<tr><td colspan="10" class="loading">Loading payroll...</td></tr>`;

    try{

        const res = await fetch(`${BASE}/api/payroll?date=${selectedDate}`,{
            credentials:"include"
        });

        const data = await res.json();

        if(!res.ok){
            table.innerHTML=`<tr><td colspan="10">Failed to load data</td></tr>`;
            return;
        }

        payrollData = data.experts || [];

        renderTable();

    }catch(err){
        table.innerHTML=`<tr><td colspan="10">Network error</td></tr>`;
    }
}

/* ================= RENDER ================= */
function renderTable(){

    const table=document.getElementById("summaryTable");
    table.innerHTML="";

    let totalKES = 0;

    if(payrollData.length===0){
        table.innerHTML=`<tr><td colspan="10">No data found</td></tr>`;
        return;
    }

    payrollData.forEach(e=>{

        const usd = Number(e.totalUSD || 0);
        const kes = Number(e.totalKES || 0);

        if(e.status==="PENDING"){
            totalKES += kes;
        }

        table.innerHTML+=`
        <tr>
        <td>${e.REG_NO}</td>
        <td>${e.EXPERT_NAME}</td>
        <td>${e.EXPERT_PHONE}</td>
        <td>${e.completedAssignments}</td>

        <td>
        $${usd.toLocaleString()}<br>
        <small>KES ${kes.toLocaleString()}</small>
        </td>

        <td class="
        ${e.status==="PAID"?"status-paid":
          e.status==="PROCESSING"?"status-processing":
          e.status==="FAILED"?"status-failed":
          "status-pending"}
        ">
        ${e.status}
        </td>

        <td>
        ${
        e.status==="FAILED"
        ? `${e.retryCount || 0} / ${MAX_RETRIES}
           ${(e.retryCount || 0) >= MAX_RETRIES
             ? "<div class='loading'>Max reached</div>"
             : ""}`
        : "-"
        }
        </td>

        <td>
        ${
        e.nextRetryAt
        ? new Date(e.nextRetryAt).toLocaleString()
        : "-"
        }
        </td>

        <td>${e.transactionCode || "-"}</td>

        <td>
        ${
        (e.status==="PAID" || selectedWeekIsCurrent)
        ? "-"
        : e.status==="PROCESSING"
            ? "<span class='loading'>Processing...</span>"
            : e.status==="FAILED" && (e.retryCount || 0) < MAX_RETRIES
                ? `<button onclick="payExpert('${e.REG_NO}')">Retry</button>`
                : `<button onclick="payExpert('${e.REG_NO}')">Pay</button>`
        }
        </td>

        </tr>
        `;
    });

    document.getElementById("totalAmount").innerText =
    totalKES.toLocaleString();

    document.getElementById("payAllBtn").disabled = selectedWeekIsCurrent;
}

/* ================= PAY ONE ================= */
async function payExpert(regNo){

    if(selectedWeekIsCurrent){
        alert("Payments are locked for current week");
        return;
    }

    if(!confirm("Confirm payment?")) return;

    disableButtons(true);

    try{

        const res = await fetch(`${BASE}/api/payroll/pay-expert`,{
            method:"POST",
            headers:{"Content-Type":"application/json"},
            credentials:"include",
            body:JSON.stringify({ date:selectedDate, regNo })
        });

        const data = await res.json();

        if(!res.ok){
            alert(data.message || "Payment failed");
            return;
        }

        loadWeek();

    }catch(err){
        alert("Network error");
    }

    disableButtons(false);
}

/* ================= PAY ALL ================= */
async function payAll(){

    if(selectedWeekIsCurrent){
        alert("Payments are locked for current week");
        return;
    }

    if(!confirm("Pay ALL experts?")) return;

    disableButtons(true);

    try{

        const res = await fetch(`${BASE}/api/payroll/pay-all`,{
            method:"POST",
            headers:{"Content-Type":"application/json"},
            credentials:"include",
            body:JSON.stringify({ date:selectedDate })
        });

        const data = await res.json();

        if(!res.ok){
            alert(data.message || "Payment failed");
            return;
        }

        loadWeek();

    }catch(err){
        alert("Network error");
    }

    disableButtons(false);
}

/* ================= DOWNLOAD ================= */
async function downloadPayroll(){

    if(!selectedWeek){
        alert("Select week first");
        return;
    }

    const res = await fetch(`${BASE}/api/payroll/download`,{
        method:"POST",
        headers:{"Content-Type":"application/json"},
        credentials:"include",
        body:JSON.stringify({ date:selectedDate })
    });

    if(!res.ok){
        alert("Failed to download payroll");
        return;
    }

    const blob = await res.blob();
    const url = window.URL.createObjectURL(blob);

    const a=document.createElement("a");
    a.href=url;
    a.download=`Payroll_${selectedWeek}.csv`;
    a.click();
}

/* ================= UTIL ================= */
function disableButtons(state){
    document.querySelectorAll("button").forEach(b=>b.disabled=state);
}

</script>

</body>
</html>