<!DOCTYPE html>
<html lang="en">

<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>Admin Completed Assignments</title>

<style>

*{ box-sizing:border-box; margin:0; padding:0; }

body{
font-family:Arial,sans-serif;
background:#f5f5f5;
padding-bottom:70px;
}

.container{
max-width:900px;
margin:auto;
padding:20px;
}

h2{
margin-bottom:20px;
color:#333;
}

.assignment{
background:white;
border:1px solid #ddd;
padding:15px;
margin-bottom:10px;
border-radius:8px;
display:flex;
justify-content:space-between;
align-items:center;
}

.assignment-info{
display:flex;
flex-direction:column;
gap:4px;
}

.assignment button{
background:#8B4513;
color:white;
border:none;
padding:8px 14px;
border-radius:5px;
cursor:pointer;
}

.assignment button:hover{
background:#6f3610;
}

.empty{
text-align:center;
color:#444;
padding:30px;
font-size:18px;
}

.loading{
text-align:center;
padding:30px;
font-size:16px;
color:#555;
}

footer{
position:fixed;
bottom:0;
width:100%;
text-align:center;
background:#8B4513;
color:white;
padding:12px;
}

</style>
</head>

<body>

<!-- ✅ REUSABLE COMPONENTS -->
<%- include("partials/header") %>
<%- include("partials/top-menu") %>

<div class="container">

<h2>Completed Assignments</h2>

<div id="loading" class="loading">
Loading completed assignments...
</div>

<ol id="list" style="display:none;"></ol>

<div id="empty" class="empty" style="display:none;">
No completed assignments
</div>

</div>

<footer>
© 2026 Electro-Aid Technologies
</footer>

<script>

async function load(){

const loading = document.getElementById("loading");
const list = document.getElementById("list");
const empty = document.getElementById("empty");

try{

const res = await fetch(
"/admin/assignments/completed/api/list",
{ credentials:"include" }
);

if(!res.ok){
throw new Error("Failed");
}

const data = await res.json();

loading.style.display = "none";
list.innerHTML = "";

if(!Array.isArray(data) || data.length === 0){
empty.style.display = "block";
return;
}

list.style.display = "block";

data.forEach(a => {

const li = document.createElement("li");
li.className = "assignment";

li.innerHTML = `

<div class="assignment-info">
<span><strong>Reference:</strong> ${a.reference || "-"}</span>
<span><strong>Title:</strong> ${a.title || "-"}</span>
<span><strong>Expert:</strong> ${a.EXPERT_NAME || "Not assigned"}</span>
<span><strong>Status:</strong> ${a.status || "-"}</span>
</div>

<button onclick="viewDetails('${a.reference}')">
View
</button>

`;

list.appendChild(li);

});

}catch(err){

console.error(err);
loading.innerText = "Failed to load completed assignments.";

}

}

function viewDetails(reference){
window.location.href =
`/admin/assignments/completed/view?ref=${reference}`;
}

load();

</script>

</body>
</html>