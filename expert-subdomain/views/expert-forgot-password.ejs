<!DOCTYPE html>
<html lang="en">
<head>

<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>Expert Forgot Password | Electro-Aid Technologies</title>

<style>

*{box-sizing:border-box;margin:0;padding:0;}

body{
font-family:Arial, Helvetica, sans-serif;
background:#f0f2f5;
}

header{
background:#8B4513;
color:white;
text-align:center;
padding:18px;
font-size:22px;
font-weight:bold;
}

main{
display:flex;
justify-content:center;
align-items:center;
padding:40px 15px;
}

.container{
background:white;
width:100%;
max-width:420px;
padding:30px;
border-radius:12px;
box-shadow:0 8px 25px rgba(0,0,0,0.15);
}

.container h2{
text-align:center;
margin-bottom:15px;
color:#8B4513;
}

.container p{
text-align:center;
margin-bottom:20px;
color:#555;
font-size:14px;
}

label{
font-weight:bold;
display:block;
margin-top:12px;
margin-bottom:5px;
}

input{
width:100%;
padding:12px;
border:1px solid #ddd;
border-radius:8px;
font-size:15px;
}

button.submit-btn{
margin-top:20px;
width:100%;
padding:13px;
border:none;
border-radius:8px;
background:#8B4513;
color:white;
font-size:16px;
cursor:pointer;
font-weight:bold;
}

button.submit-btn:hover{
background:#6f3610;
}

.message{
text-align:center;
margin-top:15px;
font-weight:bold;
}

.footer{
text-align:center;
padding:15px;
color:#777;
font-size:14px;
}

</style>

</head>

<body>

<header>
Expert Password Recovery
</header>

<main>

<div class="container">

<h2>Forgot Your Password?</h2>

<p>Enter your registered email to generate a reset link.</p>

<form id="EXPERT_FORGOT_PASSWORD_FORM">

<label>Email Address</label>
<input type="email" id="EXPERT_EMAIL" required>

<button type="submit" class="submit-btn" id="EXPERT_FORGOT_PASSWORD_BTN">
Generate Reset Link
</button>

</form>

<div id="EXPERT_FORGOT_PASSWORD_MESSAGE" class="message"></div>

</div>

</main>

<div class="footer">
© 2026 Electro-Aid Technologies
</div>

<script>

/* CONSTANTS */

const EXPERT_FORGOT_PASSWORD_FORM =
document.getElementById("EXPERT_FORGOT_PASSWORD_FORM")

const EXPERT_EMAIL =
document.getElementById("EXPERT_EMAIL")

const EXPERT_FORGOT_PASSWORD_BTN =
document.getElementById("EXPERT_FORGOT_PASSWORD_BTN")

const EXPERT_FORGOT_PASSWORD_MESSAGE =
document.getElementById("EXPERT_FORGOT_PASSWORD_MESSAGE")

/* ✅ CORRECT API */
const EXPERT_FORGOT_PASSWORD_API =
"/expert/forgot-password"

/* FORM */

EXPERT_FORGOT_PASSWORD_FORM.addEventListener(
"submit",
async function(e){

e.preventDefault()

EXPERT_FORGOT_PASSWORD_BTN.disabled=true
EXPERT_FORGOT_PASSWORD_MESSAGE.innerText=""

try{

const response = await fetch(
EXPERT_FORGOT_PASSWORD_API,
{
method:"POST",
headers:{
"Content-Type":"application/json"
},
body:JSON.stringify({
EXPERT_EMAIL:EXPERT_EMAIL.value.trim()
})
}
)

const data = await response.json()

if(!response.ok){

EXPERT_FORGOT_PASSWORD_MESSAGE.style.color="red"
EXPERT_FORGOT_PASSWORD_MESSAGE.innerText=
data.message || "Email not found"

EXPERT_FORGOT_PASSWORD_BTN.disabled=false
return

}

EXPERT_FORGOT_PASSWORD_MESSAGE.style.color="green"
EXPERT_FORGOT_PASSWORD_MESSAGE.innerText=
"Reset link sent to your email"

EXPERT_FORGOT_PASSWORD_BTN.disabled=false

}catch(err){

EXPERT_FORGOT_PASSWORD_MESSAGE.style.color="red"
EXPERT_FORGOT_PASSWORD_MESSAGE.innerText=
"Server error"

EXPERT_FORGOT_PASSWORD_BTN.disabled=false

}

})

</script>

</body>
</html>