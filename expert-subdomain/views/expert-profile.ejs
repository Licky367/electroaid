<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>Expert Profile | Electro-Aid Technologies</title>

<style>
*{box-sizing:border-box;margin:0;padding:0;}

body{
font-family:Arial, Helvetica, sans-serif;
background:#f0f2f5;
padding-bottom:90px;
}

header{
text-align:center;
background:#8B4513;
color:white;
padding:18px;
font-size:22px;
font-weight:bold;
}

main{
max-width:720px;
margin:30px auto;
padding:0 15px;
}

.profile-card{
background:white;
border-radius:14px;
padding:30px;
box-shadow:0 8px 25px rgba(0,0,0,0.15);
text-align:center;
margin-bottom:20px;
}

.profile-img{
width:130px;
height:130px;
border-radius:50%;
object-fit:cover;
border:4px solid #8B4513;
margin-bottom:15px;
}

.profile-name{
font-size:24px;
font-weight:bold;
color:#333;
margin-bottom:15px;
}

.details{
text-align:left;
margin-top:15px;
}

.detail-row{
display:flex;
justify-content:space-between;
padding:12px 0;
border-bottom:1px solid #eee;
}

.label{
font-weight:bold;
color:#444;
}

.edit-btn{
display:inline-block;
margin-top:20px;
background:#8B4513;
color:white;
padding:10px 18px;
border-radius:8px;
font-weight:bold;
text-decoration:none;
}

.edit-btn:hover{
background:#6e350f;
}

.stats{
margin-top:25px;
display:flex;
flex-direction:column;
gap:12px;
}

.stat-card{
background:#8B4513;
color:white;
padding:14px;
border-radius:10px;
display:flex;
justify-content:space-between;
align-items:center;
}

.stat-label{font-weight:bold;}
.stat-value{font-size:18px;}
.rating{color:#FFD700;font-size:18px;}

.footer{
position:fixed;
bottom:0;
width:100%;
background:#8B4513;
color:white;
text-align:center;
padding:12px;
}
</style>
</head>

<body>

<header>
Expert Profile
</header>

<main>

<div class="profile-card">

<img class="profile-img"
src="<%= EXPERT_PROFILE_IMAGE || '/images/avatar.png' %>">

<div class="profile-name">
<%= EXPERT_NAME %>
</div>

<div class="details">

<div class="detail-row">
<span class="label">Email</span>
<span><%= EXPERT_EMAIL %></span>
</div>

<div class="detail-row">
<span class="label">Phone</span>
<span><%= EXPERT_PHONE || 'N/A' %></span>
</div>

<div class="detail-row">
<span class="label">Registration Number</span>
<span><%= REG_NO %></span>
</div>

</div>

<!-- ✅ CORRECT ROUTE -->
<a href="/expert/edit" class="edit-btn">
Edit Profile
</a>

<div class="stats">

<div class="stat-card">
<span class="stat-label">Average Rating</span>
<span class="stat-value rating">
<%= averageRating ? averageRating.toFixed(2) : "0.00" %> ⭐
</span>
</div>

<div class="stat-card">
<span class="stat-label">Assignments Completed</span>
<span class="stat-value">
<%= totalCompleted || 0 %>
</span>
</div>

<div class="stat-card">
<span class="stat-label">Total Payout ($)</span>
<span class="stat-value">
$<%= Number(totalPayout || 0).toLocaleString() %>
</span>
</div>

<div class="stat-card">
<span class="stat-label">Average Payout ($)</span>
<span class="stat-value">
$<%= averagePayout ? averagePayout.toFixed(2) : "0.00" %>
</span>
</div>

</div>

</div>

</main>

<div class="footer">
© <%= new Date().getFullYear() %> Electro-Aid Technologies
</div>

</body>
</html>