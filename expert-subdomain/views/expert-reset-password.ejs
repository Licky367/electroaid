<!DOCTYPE html>
<html lang="en">
<head>

<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>Expert Reset Password | Electro-Aid Technologies</title>

<style>

*{box-sizing:border-box;margin:0;padding:0;}

body{
font-family:Arial, Helvetica, sans-serif;
background:#f0f2f5;
}

header{
background:#8B4513;
color:white;
text-align:center;
padding:18px;
font-size:22px;
font-weight:bold;
}

main{
display:flex;
justify-content:center;
align-items:center;
padding:40px 15px;
}

.container{
background:white;
width:100%;
max-width:420px;
padding:30px;
border-radius:12px;
box-shadow:0 8px 25px rgba(0,0,0,0.15);
}

.container h2{
text-align:center;
color:#8B4513;
margin-bottom:20px;
}

label{
display:block;
margin-top:12px;
font-weight:bold;
margin-bottom:5px;
}

input{
width:100%;
padding:12px;
border:1px solid #ddd;
border-radius:8px;
font-size:15px;
}

.password-field{
position:relative;
}

.password-field button{
position:absolute;
right:10px;
top:50%;
transform:translateY(-50%);
border:none;
background:none;
cursor:pointer;
font-size:14px;
}

button.submit-btn{
margin-top:20px;
width:100%;
padding:13px;
border:none;
border-radius:8px;
background:#8B4513;
color:white;
font-size:16px;
cursor:pointer;
font-weight:bold;
}

.message{
text-align:center;
margin-top:15px;
font-weight:bold;
}

.footer{
text-align:center;
padding:15px;
color:#777;
font-size:14px;
}

</style>

</head>

<body>

<header>
Reset Expert Password
</header>

<main>

<div class="container">

<h2>Create New Password</h2>

<form id="EXPERT_RESET_PASSWORD_FORM">

<label>New Password</label>

<div class="password-field">
<input type="password" id="EXPERT_NEW_PASSWORD" required>
<button type="button" id="EXPERT_PASSWORD_TOGGLE">Show</button>
</div>

<label>Confirm Password</label>

<div class="password-field">
<input type="password" id="EXPERT_CONFIRM_PASSWORD" required>
<button type="button" id="EXPERT_CONFIRM_PASSWORD_TOGGLE">Show</button>
</div>

<button
type="submit"
class="submit-btn"
id="EXPERT_RESET_PASSWORD_BTN">
Reset Password
</button>

</form>

<div id="EXPERT_RESET_PASSWORD_MESSAGE" class="message"></div>

</div>

</main>

<div class="footer">
© 2026 Electro-Aid Technologies
</div>

<script>

/* CONSTANTS */

const EXPERT_RESET_PASSWORD_FORM =
document.getElementById("EXPERT_RESET_PASSWORD_FORM")

const EXPERT_NEW_PASSWORD =
document.getElementById("EXPERT_NEW_PASSWORD")

const EXPERT_CONFIRM_PASSWORD =
document.getElementById("EXPERT_CONFIRM_PASSWORD")

const EXPERT_PASSWORD_TOGGLE =
document.getElementById("EXPERT_PASSWORD_TOGGLE")

const EXPERT_CONFIRM_PASSWORD_TOGGLE =
document.getElementById("EXPERT_CONFIRM_PASSWORD_TOGGLE")

const EXPERT_RESET_PASSWORD_BTN =
document.getElementById("EXPERT_RESET_PASSWORD_BTN")

const EXPERT_RESET_PASSWORD_MESSAGE =
document.getElementById("EXPERT_RESET_PASSWORD_MESSAGE")

/* ✅ CORRECT API */
const EXPERT_RESET_PASSWORD_API =
"/expert/reset-password"

/* TOKEN */

const EXPERT_RESET_TOKEN =
new URLSearchParams(window.location.search)
.get("token")

/* PASSWORD TOGGLE */

EXPERT_PASSWORD_TOGGLE.onclick=()=>{
EXPERT_NEW_PASSWORD.type=
EXPERT_NEW_PASSWORD.type==="password"
? "text":"password"
}

EXPERT_CONFIRM_PASSWORD_TOGGLE.onclick=()=>{
EXPERT_CONFIRM_PASSWORD.type=
EXPERT_CONFIRM_PASSWORD.type==="password"
? "text":"password"
}

/* RESET */

EXPERT_RESET_PASSWORD_FORM.addEventListener(
"submit",
async function(e){

e.preventDefault()

if(!EXPERT_RESET_TOKEN){

EXPERT_RESET_PASSWORD_MESSAGE.style.color="red"
EXPERT_RESET_PASSWORD_MESSAGE.innerText=
"Invalid reset link"
return
}

const NEW_PASSWORD = EXPERT_NEW_PASSWORD.value.trim()
const CONFIRM_PASSWORD = EXPERT_CONFIRM_PASSWORD.value.trim()

if(NEW_PASSWORD !== CONFIRM_PASSWORD){

EXPERT_RESET_PASSWORD_MESSAGE.style.color="red"
EXPERT_RESET_PASSWORD_MESSAGE.innerText=
"Passwords do not match"
return
}

try{

EXPERT_RESET_PASSWORD_BTN.disabled=true

const response = await fetch(
EXPERT_RESET_PASSWORD_API,
{
method:"POST",
headers:{
"Content-Type":"application/json"
},
body:JSON.stringify({
EXPERT_RESET_TOKEN,
EXPERT_NEW_PASSWORD: NEW_PASSWORD
})
}
)

const data = await response.json()

if(!response.ok){

EXPERT_RESET_PASSWORD_MESSAGE.style.color="red"
EXPERT_RESET_PASSWORD_MESSAGE.innerText=
data.message || "Reset failed"

EXPERT_RESET_PASSWORD_BTN.disabled=false
return

}

EXPERT_RESET_PASSWORD_MESSAGE.style.color="green"
EXPERT_RESET_PASSWORD_MESSAGE.innerText=
"Password reset successful"

/* ✅ CORRECT REDIRECT */
setTimeout(()=>{
window.location.href="/expert/login"
},2000)

}catch(err){

EXPERT_RESET_PASSWORD_MESSAGE.style.color="red"
EXPERT_RESET_PASSWORD_MESSAGE.innerText=
"Server error"

EXPERT_RESET_PASSWORD_BTN.disabled=false

}

})

</script>

</body>
</html>