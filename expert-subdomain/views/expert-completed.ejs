<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Expert Completed Assignments | Electro-Aid Technologies</title>

<style>
body{
    font-family: Arial, sans-serif;
    background:#f5f5f5;
    margin:0;
}
header{
    background:#8B4513;
    color:white;
    padding:15px;
    text-align:center;
}
.container{
    max-width:900px;
    margin:auto;
    padding:20px;
}
h2{
    margin-bottom:10px;
}
ol{
    padding-left:20px;
}
.assignment{
    background:white;
    border:1px solid #ddd;
    padding:15px;
    margin-bottom:10px;
    border-radius:6px;
    display:flex;
    justify-content:space-between;
    align-items:center;
}
.assignment-info{
    display:flex;
    flex-direction:column;
    gap:4px;
}
.assignment button{
    background:#8B4513;
    color:white;
    border:none;
    padding:8px 14px;
    border-radius:4px;
    cursor:pointer;
}
.assignment button:hover{
    background:#6f3610;
}
.empty{
    text-align:center;
    color:#444;
    padding:30px;
    font-size:18px;
}

/* RATING */
.expert-rating{
    font-weight:bold;
    margin-bottom:15px;
    font-size:1.1rem;
    display:flex;
    align-items:center;
    gap:10px;
}
.stars{
    display:inline-block;
    position: relative;
    font-size:1.2rem;
    color:#ccc;
}
.stars .filled{
    position:absolute;
    top:0;
    left:0;
    white-space: nowrap;
    overflow:hidden;
    color:#FFD700;
}
.stars span{
    pointer-events:none;
}
</style>
</head>

<body>

<header>
<h1>Expert Completed Assignments</h1>
</header>

<div class="container">

<h2>
Assignments You Completed (<%= totalCompleted %>)
</h2>

<!-- EXPERT RATING -->
<div class="expert-rating">
    Average Rating:
    <div class="stars">
        <div class="filled" style="width:<%= (averageRating/5)*100 %>%">
            ★★★★★
        </div>
        <span>★★★★★</span>
    </div>
    (<%= averageRating.toFixed(2) %>)
</div>

<% if (assignments.length === 0) { %>

<div class="empty">
You have no completed assignments
</div>

<% } else { %>

<ol>

<% assignments.forEach(assignment => { %>

<li class="assignment">

    <div class="assignment-info">
        <span><strong>Reference:</strong> <%= assignment.reference %></span>
        <span><strong>Title:</strong> <%= assignment.title %></span>
        <span><strong>Payout:</strong> KES <%= Number(assignment.payout).toLocaleString() %></span>
    </div>

    <!-- ✅ FIXED ROUTE -->
    <button onclick="window.location.href='/expert/assignments/completed-view?ref=<%= assignment.reference %>'">
        View Details
    </button>

</li>

<% }) %>

</ol>

<% } %>

</div>

</body>
</html>