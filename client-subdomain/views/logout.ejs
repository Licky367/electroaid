<!DOCTYPE html>
<html lang="en">
<head>

<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>Logout Confirmation | Electro-Aid Technologies</title>

<style>
*{
margin:0;
padding:0;
box-sizing:border-box;
}

body{
font-family:Arial,sans-serif;
background:#8B4513;
display:flex;
justify-content:center;
align-items:center;
height:100vh;
}

.container{
background:white;
padding:30px 25px;
width:90%;
max-width:400px;
border-radius:20px;
box-shadow:0 10px 25px rgba(0,0,0,0.35);
text-align:center;
}

h2{
color:#8B4513;
margin-bottom:20px;
}

p{
font-size:0.95rem;
color:#555;
margin-bottom:30px;
}

.button-group{
display:flex;
justify-content:space-between;
gap:10px;
}

button, a{
padding:10px 20px;
border:none;
border-radius:10px;
cursor:pointer;
font-weight:bold;
min-width:100px;
text-decoration:none;
display:inline-block;
text-align:center;
}

.cancel-btn{
background:#ccc;
color:#333;
}

.confirm-btn{
background:#D2691E;
color:white;
}

.confirm-btn:hover{
background:#A0522D;
}

.cancel-btn:hover{
background:#b3b3b3;
}
</style>

</head>

<body>

<div class="container">

<h2>Are you sure you want to log out?</h2>

<p>You will need to log in again to access your account.</p>

<div class="button-group">

<button class="cancel-btn" onclick="window.history.back()">
Cancel
</button>

<a href="/auth/logout" class="confirm-btn">
Okay
</a>

</div>

</div>

</body>
</html>